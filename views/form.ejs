<form method="POST" action="/new">
    <h2>
        Authors Message Form!
    </h2>
    <div>
        <label for="messageUser">AUTHOR'S NAME</label>
        <input type="text" id="messageUser" name="messageUser">
    </div>
    <div>
        <label for="messageText">MESSAGE</label>
        <input type="text" id="messageText" name="messageText">
    </div>
    <div>
        <button class="submit" type="submit">Post Message</button>
    </div>
 </form>
 